# =============================================================================
# WhatsApp B2B AI Agent — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the real values.
# NEVER commit the `.env` file to version control.
# =============================================================================

# --- Application ---
APP_PORT=8000
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
TENANT_CONFIG_DIR=./tenants             # Path to tenant configuration directory

# --- Google Gemini AI ---
GEMINI_API_KEY=AIza
GEMINI_MODEL=gemini-2.0-flash          # Model to use for responses

# --- Redis (Semantic Cache) ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redis123local

# --- Qdrant (Conversation History) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=conversations

# --- WAHA (WhatsApp HTTP API) ---
WAHA_API_URL=http://waha:3000/
WAHA_API_KEY=waha123localtest
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=waha123localtest
WAHA_SWAGGER_USERNAME=admin
WAHA_SWAGGER_PASSWORD=waha123localtest

# --- Webhook Security ---
WEBHOOK_SECRET=webhook123local
