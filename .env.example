# =============================================================================
# WhatsApp B2B AI Agent — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the real values.
# NEVER commit the `.env` file to version control.
# =============================================================================

# --- Application ---
APP_PORT=8000
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
TENANT_CONFIG_DIR=./tenants             # Path to tenant configuration directory

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash          # Model to use for responses

# --- Redis (Semantic Cache) ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-redis-password-here

# --- Qdrant (Conversation History) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=conversations

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key-here

# --- Webhook Security ---
WEBHOOK_SECRET=your-webhook-signing-secret-here
